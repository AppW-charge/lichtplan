    case 'nood': return`<rect x="2" y="9" width="26" height="12" rx="3" fill="#2a0808" stroke="#ff4455" stroke-width="2"/><text x="15" y="19" text-anchor="middle" font-size="10" fill="#ff4455" font-weight="700" font-family="sans-serif">E</text><line x1="7" y1="9" x2="4" y2="5" stroke="#ff4455" stroke-width="1.5"/><line x1="23" y1="9" x2="26" y2="5" stroke="#ff4455" stroke-width="1.5"/>`;
