    case 'schakelaar': return`<circle cx="15" cy="15" r="10" fill="#1a2030" stroke="#5a7a99" stroke-width="2"/><line x1="15" y1="5" x2="15" y2="15" stroke="#5a7a99" stroke-width="2.5" stroke-linecap="round"/><line x1="15" y1="15" x2="22" y2="22" stroke="#5a7a99" stroke-width="2" stroke-linecap="round"/>`;
    default: return`<circle cx="15" cy="15" r="10" fill="none" stroke="#fff" stroke-width="2"/>`;
  }
