    // Dubbele TL — twee buizen
    case 'tl2': return`<rect x="2" y="9" width="26" height="5" rx="2.5" fill="#1a2030" stroke="#dce8f5" stroke-width="1.5"/><rect x="4" y="10" width="22" height="3" rx="1.5" fill="#dce8f5" opacity=".3"/>
      <rect x="2" y="16" width="26" height="5" rx="2.5" fill="#1a2030" stroke="#dce8f5" stroke-width="1.5"/><rect x="4" y="17" width="22" height="3" rx="1.5" fill="#dce8f5" opacity=".3"/>
      <line x1="7" y1="9" x2="7" y2="6" stroke="#dce8f5" stroke-width="1.5"/><line x1="23" y1="9" x2="23" y2="6" stroke="#dce8f5" stroke-width="1.5"/>
      <line x1="7" y1="21" x2="7" y2="24" stroke="#dce8f5" stroke-width="1.5"/><line x1="23" y1="21" x2="23" y2="24" stroke="#dce8f5" stroke-width="1.5"/>`;
    // EX Armatuur TL — gestreept kader (explosieveilig)
    case 'extl': return`<rect x="1" y="10" width="28" height="10" rx="2" fill="#1a1005" stroke="#ff8833" stroke-width="2" stroke-dasharray="3 2"/><rect x="3" y="12" width="24" height="6" rx="3" fill="#1a2030" stroke="#dce8f5" stroke-width="1.5"/><rect x="5" y="13.5" width="20" height="3" rx="1.5" fill="#dce8f5" opacity=".3"/>
      <text x="15" y="8" text-anchor="middle" font-size="5.5" fill="#ff8833" font-family="sans-serif" font-weight="700">EX</text>
      <line x1="8" y1="18" x2="8" y2="22" stroke="#ff8833" stroke-width="1.5"/><line x1="22" y1="18" x2="22" y2="22" stroke="#ff8833" stroke-width="1.5"/>`;
    // EX LED — explosieveilig ronde armatuur
    case 'exled': return`<circle cx="15" cy="15" r="11" fill="#1a0a00" stroke="#ff8833" stroke-width="2" stroke-dasharray="3 2"/>
      <circle cx="15" cy="15" r="6" fill="#1a2030" stroke="#ffaa22" stroke-width="1.5"/>
      <circle cx="15" cy="15" r="3" fill="#ffaa22"/>
      <text x="15" y="6" text-anchor="middle" font-size="4.5" fill="#ff8833" font-family="sans-serif" font-weight="700">EX</text>
      ${[...Array(6)].map((_,i)=>{const a=i*Math.PI/3;return`<line x1="${(15+7*Math.cos(a)).toFixed(1)}" y1="${(15+7*Math.sin(a)).toFixed(1)}" x2="${(15+10*Math.cos(a)).toFixed(1)}" y2="${(15+10*Math.sin(a)).toFixed(1)}" stroke="#ffaa22" stroke-width="1.5" opacity=".6"/>`;}).join('')}`;
