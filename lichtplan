  const el=elements.find(e=>e.id===selectedId);
  if(!el){pane.innerHTML='';return;}
  const connKb=cables.filter(c=>c.fromId===el.id||c.toId===el.id);
  const rot=el.rotation||0;
  const isArm=TYPEINFO[el.type]?.cat==='arm';

  pane.innerHTML=`
    <div class="prop-head">${TYPEINFO[el.type]?.icon||'?'} ${TYPEINFO[el.type]?.lbl||el.type}</div>

    <div class="prow"><div class="plbl2">Referentie / Label</div>
      <input class="pinp" value="${el.label}" oninput="onLabelChange('${el.id}',this.value)">
    </div>

    ${isArm?`
    <div class="prow"><div class="plbl2">Richting armatuur</div>
      <div class="rot-row">
        <div class="rot-btn ${rot===0?'act':''}" onclick="setElemRot('${el.id}',0)">— Horizontaal</div>
        <div class="rot-btn ${rot===90?'act':''}" onclick="setElemRot('${el.id}',90)">| Verticaal</div>
        <div class="rot-btn ${rot===45?'act':''}" onclick="setElemRot('${el.id}',45)">∕ 45°</div>
        <div class="rot-btn ${rot!==0&&rot!==90&&rot!==45?'act':''}" onclick="setElemRotCustom('${el.id}')">⟳</div>
      </div>
    </div>`:''}

    ${el.type==='kast'?`<div class="prow"><div class="plbl2">Kastomschrijving</div>
      <input class="pinp" placeholder="Bv. 24-mod Hager 3-fase" value="${el.kasttype||''}" oninput="elements.find(e=>e.id==='${el.id}').kasttype=this.value">
    </div>`:''}

    ${isArm?`<div class="prow"><div class="plbl2">Armatuurtype / Omschrijving</div>
      <input class="pinp" placeholder="Bv. Philips RC127B LED 36W" value="${el.armatuurtype||''}" oninput="elements.find(e=>e.id==='${el.id}').armatuurtype=this.value">
    </div>
    <div class="prow"><div class="plbl2">Vermogen (W)</div>
      <input class="pinp" type="number" value="${el.watt||0}" oninput="elements.find(e=>e.id==='${el.id}').watt=+this.value">
    </div>`:''}

    <div class="prow"><div class="plbl2">Kring</div>
      <select class="psel" onchange="elements.find(e=>e.id==='${el.id}').circuit=this.value;redraw()">
        ${circuits.map(c=>`<option value="${c.id}" ${c.id===el.circuit?'selected':''}>${c.name}</option>`).join('')}
      </select>
    </div>

    <div class="prow"><div class="plbl2">Notitie</div>
      <input class="pinp" value="${el.notes||''}" oninput="elements.find(e=>e.id==='${el.id}').notes=this.value">
    </div>

    <div class="prow"><div class="plbl2">Hoogte / Niveau (m)</div>
      <input class="pinp" type="text" placeholder="Bv. 3.00 m" value="${el.hoogte||''}" oninput="elements.find(e=>e.id==='${el.id}').hoogte=this.value;redraw()">
    </div>

    ${connKb.length?`<div class="plbl2" style="margin:10px 0 5px">Verbonden kabels (${connKb.length})</div>
    ${connKb.map(c=>{
      const other=elements.find(e=>e.id===(c.fromId===el.id?c.toId:c.fromId));
      const dir=c.fromId===el.id?'→':'←';
      const len=cLen(c).toFixed(2);
      return`<div style="background:var(--blue);border-left:3px solid ${c.color||'#fff'};border-radius:0 4px 4px 0;padding:5px 8px;margin-bottom:3px;font-size:10px;line-height:1.8;cursor:pointer" onclick="selectedId='cable:${c.id}';renderProps();redraw()">
        <div style="color:${c.color||'#fff'};font-weight:700">${c.kabelnr} ${dir} ${other?other.label:'?'}</div>
        <div style="color:var(--dim)">${c.kabeltype||'—'} · <span style="color:var(--amber)">${len}m</span></div>
      </div>`;
    }).join('')}`:''}

    <div style="display:flex;gap:5px;margin-top:8px">
      <button class="pdelbtn" style="flex:1;margin:0" onclick="delElem('${el.id}')">🗑 Verwijder</button>
      <button style="flex:1;background:var(--blue2);border:1px solid var(--border2);color:var(--text);padding:5px;border-radius:4px;cursor:pointer;font-size:11px" onclick="duplicateElem('${el.id}')">⧉ Dupliceer</button>
    </div>`;
}

function delWaypoint(cid,idx){
  const c=cables.find(x=>x.id===cid);if(!c||!c.wpts)return;
  c.wpts.splice(idx,1);
  renderProps();redraw();
}
  const el=elements.find(e=>e.id===id);if(!el)return;
  el.rotation=deg;renderProps();redraw();
}
function setElemRotCustom(id){
  const el=elements.find(e=>e.id===id);if(!el)return;
  const v=prompt('Hoek in graden (0-359):',String(el.rotation||0));
  if(v===null)return;
  el.rotation=((+v)%360+360)%360;
  renderProps();redraw();
}
function duplicateElem(id){
  const src=elements.find(e=>e.id===id);if(!src)return;
  const nid='e'+nextId++;
  const copy={...src,id:nid,x:src.x+30,y:src.y+30};
  elements.push(copy);
  selectedId=nid;renderProps();renderElemList();updateStatus();redraw();
}

// ── ELEMENT LIST ──────────────────────────────────────────────────────────────
function renderElemList(){
  const el=document.getElementById('rList');
  const TI=allTypeInfo();
  const order=getPaletteOrder();
  if(!elements.length&&!cables.length){el.innerHTML='<div class="pempty">Nog geen elementen geplaatst</div>';return;}
  let html='';
  order.forEach(t=>{
    const els=elements.filter(e=>e.type===t);if(!els.length)return;
    html+=`<div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--dim);padding:7px 0 3px;font-weight:700">${TI[t]?.lbl||t} (${els.length})</div>`;
    els.forEach(e=>{
      const circ=circuits.find(c=>c.id===e.circuit);
      html+=`<div style="display:flex;align-items:center;gap:5px;padding:4px 7px;background:var(--blue);border:1px solid ${selectedId===e.id?'var(--green)':'var(--border2)'};border-radius:4px;margin-bottom:3px;cursor:pointer;font-size:11px" onclick="selectAndJump('${e.id}')">
        <div style="width:7px;height:7px;border-radius:50%;background:${circ?circ.color:'#fff'};flex-shrink:0"></div>
        <div style="flex:1">${e.label}</div>
        <div style="font-size:9px;color:var(--dim);max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${e.armatuurtype||e.kasttype||''}</div>
        <div style="font-size:9px;color:var(--amber)">${e.watt?e.watt+'W':''}</div>
      </div>`;
    });
  });
  if(cables.length){
    html+=`<div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--dim);padding:7px 0 3px;font-weight:700">Kabels (${cables.length})</div>`;
    cables.forEach(c=>{
      const from=elements.find(e=>e.id===c.fromId),to=elements.find(e=>e.id===c.toId);
      const len=cLen(c).toFixed(2);
      html+=`<div style="display:flex;align-items:center;gap:5px;padding:4px 7px;background:var(--blue);border:1px solid ${selectedId==='cable:'+c.id?'var(--green)':'var(--border2)'};border-radius:4px;margin-bottom:3px;cursor:pointer;font-size:10px" onclick="selectAndJump('cable:${c.id}')">
        <div style="width:7px;height:7px;border-radius:50%;background:${c.color||'#fff'};flex-shrink:0"></div>
        <div style="flex:1;font-weight:600">${c.kabelnr}</div>
        <div style="color:var(--dim)">${from?from.label:'?'}→${to?to.label:'?'}</div>
        <div style="color:var(--amber);font-weight:700">${len}m</div>
      </div>`;
    });
  }
  el.innerHTML=html;
}

// ── STUKLIJST ─────────────────────────────────────────────────────────────────
function renderStuk(){
  const el=document.getElementById('rStuk');
  const TI=allTypeInfo();
  const order=getPaletteOrder();
  let html=`<button class="xbtn xbtn-g" onclick="exportCSV()">⬇ Export CSV</button>
    <button class="xbtn xbtn-b" onclick="window.print()">🖨 Print</button>
    <table class="stuk-table"><tr><th>Ref</th><th>Type</th><th>Omschrijving</th><th>Kring</th></tr>`;
  order.forEach(t=>{
    const els=elements.filter(e=>e.type===t);if(!els.length)return;
    html+=`<tr><td colspan="4" class="stuk-section">${TI[t]?.lbl||t} (${els.length})</td></tr>`;
    els.forEach(e=>{
      const circ=circuits.find(c=>c.id===e.circuit);
      const desc=[e.armatuurtype||e.kasttype,e.watt?e.watt+'W':'',e.hoogte?'↕'+e.hoogte+'m':'',e.notes].filter(Boolean).join(' — ')||'—';
      html+=`<tr><td class="stuk-num">${e.label}</td><td style="font-size:9.5px">${TI[e.type]?.lbl||e.type}</td><td style="color:var(--dim);font-size:9.5px">${desc}</td><td style="color:${circ?circ.color:'#fff'};font-size:9.5px">${circ?circ.name:'?'}</td></tr>`;
    });
  });
  if(cables.length){
    html+=`<tr><td colspan="4" class="stuk-section">Kabels (${cables.length})</td></tr>`;
    html+=`<tr><th>Nr</th><th>Type</th><th>Van→Naar</th><th>m</th></tr>`;
    let tot=0;const byType={};
    cables.forEach(c=>{
      const from=elements.find(e=>e.id===c.fromId),to=elements.find(e=>e.id===c.toId);
      const len=cLen(c);tot+=len;
      const t=c.kabeltype||'Onbekend';byType[t]=(byType[t]||0)+len;
      html+=`<tr><td class="stuk-num" style="color:${c.color||'var(--green)'}">${c.kabelnr}</td><td style="font-size:9px">${t}</td><td style="color:var(--dim);font-size:9px">${from?from.label:'?'}→${to?to.label:'?'}</td><td style="color:var(--amber);font-weight:600">${len.toFixed(2)}</td></tr>`;
    });
    html+=`<tr><td colspan="3" style="text-align:right;color:var(--dim);font-size:9px">Totaal:</td><td style="color:var(--amber);font-weight:700">${tot.toFixed(2)} m</td></tr>`;
    html+=`<tr><td colspan="4" class="stuk-section">Per kabeltype (+10% marge)</td></tr>`;
    Object.entries(byType).forEach(([t,l])=>{
      html+=`<tr><td colspan="3" style="font-size:10px">${t}</td><td style="color:var(--amber);font-weight:600">${(l*1.1).toFixed(1)} m</td></tr>`;
    });
    const totW=elements.filter(e=>e.watt).reduce((s,e)=>s+e.watt,0);
    if(totW>0){
      html+=`<tr><td colspan="4" class="stuk-section">Belasting</td></tr>
        <tr><td colspan="3">Totaal vermogen</td><td style="color:var(--amber);font-weight:700">${totW} W</td></tr>
        <tr><td colspan="3">Stroom @ 230V</td><td style="color:var(--amber);font-weight:700">${(totW/230).toFixed(2)} A</td></tr>`;
    }
  }
  el.innerHTML=html+'</table>';
}

// ── STATUS ────────────────────────────────────────────────────────────────────
function updateStatus(){
  document.getElementById('sbEl').textContent=elements.length+' elementen';
  document.getElementById('sbKb').textContent=cables.length+' kabels';
  document.getElementById('sbM').textContent=cables.reduce((s,c)=>s+cLen(c),0).toFixed(1)+' m';
}

// ── SAVE / LOAD ───────────────────────────────────────────────────────────────
function saveProject(){
  const d={elements,cables,circuits,scale,nextId,nextKb,nextRef,
    circTypeCounters,lastPlacedLabel,customTypes,paletteOrder};
  const blob=new Blob([JSON.stringify(d)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='verlichtingsplan.vcp';a.click();
}
function loadProject(){
  const inp=document.createElement('input');inp.type='file';inp.accept='.vcp,.wcp,.json';
  inp.onchange=e=>{
    const f=e.target.files[0];if(!f)return;
    const r=new FileReader();
    r.onload=ev=>{
      try{
        const d=JSON.parse(ev.target.result);
        elements=d.elements||[];cables=d.cables||[];circuits=d.circuits||circuits;scale=d.scale||0.05;
        nextId=d.nextId||elements.length+1;nextKb=d.nextKb||cables.length+1;
        if(d.nextRef)nextRef=d.nextRef;
        if(d.circTypeCounters)circTypeCounters=d.circTypeCounters;
        if(d.lastPlacedLabel)lastPlacedLabel=d.lastPlacedLabel;
        if(d.customTypes)customTypes=d.customTypes;
        if(d.paletteOrder)paletteOrder=d.paletteOrder;
        // patch missing fields on old saves
        circuits.forEach(c=>{if(c.kabelnr===undefined)c.kabelnr='';});
        elements.forEach(e=>{if(e.hoogte===undefined)e.hoogte='';});
        cables.forEach(c=>{if(!c.wpts)c.wpts=[];});
        document.getElementById('scaleInput').value=scale;
        buildPalette();renderCircuits();renderElemList();renderProps();redraw();
        alert('Project geladen.\nUpload het grondplan opnieuw als het ontbreekt.');
      }catch(err){alert('Fout bij laden: '+err.message);}
    };
    r.readAsText(f);
  };
  inp.click();
}
function exportCSV(){
  const TI=allTypeInfo();
  const order=getPaletteOrder();
  let csv='ELEMENTEN\nType;Referentie;Omschrijving;Richting;Hoogte(m);Kring;Kring-kabelnr;Vermogen(W)\n';
  order.forEach(t=>{
    elements.filter(e=>e.type===t).forEach(e=>{
      const circ=circuits.find(c=>c.id===e.circuit);
      csv+=`${TI[e.type]?.lbl||e.type};${e.label};${e.armatuurtype||e.kasttype||e.notes||''};${e.rotation||0}°;${e.hoogte||''};${circ?circ.name:''};${circ?circ.kabelnr||'':''};${e.watt||0}\n`;
    });
  });
  csv+='\nKABELS\nKabelnr;Kleur;Kabeltype;Van;Naar;Lengte(m);+10%(m);Kring;Notitie\n';
  cables.forEach(c=>{
    const from=elements.find(e=>e.id===c.fromId),to=elements.find(e=>e.id===c.toId);
    const len=cLen(c).toFixed(2);
    const circ=circuits.find(ci=>ci.id===c.circuit);
    csv+=`${c.kabelnr};${c.color||''};${c.kabeltype||''};${from?from.label:''};${to?to.label:''};${len};${(+len*1.1).toFixed(2)};${circ?circ.name:''};${c.notes||''}\n`;
  });
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='verlichtingsplan.csv';a.click();
}

setMode('select');
</script>
