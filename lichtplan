function showRTab(t){
  ['props','list','stuk'].forEach(x=>{
    document.getElementById('rt-'+x).classList.toggle('act',x===t);
    document.getElementById('r'+x.charAt(0).toUpperCase()+x.slice(1)).style.display=x===t?'':'none';
  });
  if(t==='stuk')renderStuk();
  if(t==='list')renderElemList();
}

function colorSwatches(currentColor, onchange){
  const swatches=CABLE_COLORS.map(c=>`
    <div class="cswatch ${c===currentColor?'act':''}" style="background:${c}" onclick="${onchange}('${c}')" title="${c}"></div>
  `).join('');
  return `<div class="color-row">${swatches}
    <input type="color" class="cpick" value="${currentColor}" oninput="${onchange}(this.value)" title="Aangepaste kleur">
  </div>`;
}

function setCableColor(id,col){
  const c=cables.find(x=>x.id===id);if(!c)return;
