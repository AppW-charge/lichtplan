// ── DRAW ──────────────────────────────────────────────────────────────────────
function redraw(){
  const svg=document.getElementById('svg');
  svg.innerHTML='';
  const showLbl=document.getElementById('showLabels')?.checked??true;
  const showLen=document.getElementById('showLengths')?.checked??true;
  const showRef=document.getElementById('showRefs')?.checked??true;
  const showFT=document.getElementById('showFromTo')?.checked??true;

  // defs
  const defs=mkel('defs');
  [...new Set(cables.map(c=>c.color||'#d4ff00'))].forEach(col=>{
    const cid='arr'+col.replace(/[^a-zA-Z0-9]/g,'');
    const mk=mkel('marker',{id:cid,markerWidth:'8',markerHeight:'6',refX:'7',refY:'3',orient:'auto'});
    mk.appendChild(mkel('polygon',{points:'0 0,8 3,0 6',fill:col,opacity:'.95'}));
    defs.appendChild(mk);
  });
  // glow filter for highlights
  const filt=mkel('filter',{id:'glow',x:'-30%',y:'-30%',width:'160%',height:'160%'});
  const fe=mkel('feGaussianBlur',{stdDeviation:'4',result:'blur'});
  const feM=mkel('feMerge');
  const n1=mkel('feMergeNode',{in:'blur'});
  const n2=mkel('feMergeNode',{in:'SourceGraphic'});
  feM.appendChild(n1);feM.appendChild(n2);
  filt.appendChild(fe);filt.appendChild(feM);
  defs.appendChild(filt);
  svg.appendChild(defs);

  // cables
  cables.forEach(c=>{
    const pts=cPts(c);if(pts.length<2)return;
    const isSel=selectedId==='cable:'+c.id;
    const isHL=highlightId==='cable:'+c.id;
    const col=c.color||'#d4ff00';
    const cid='arr'+col.replace(/[^a-zA-Z0-9]/g,'');
    const d=pts.map((p,i)=>(i===0?`M${p.x} ${p.y}`:`L${p.x} ${p.y}`)).join(' ');
    svg.appendChild(mkel('path',{d,stroke:'#000',strokeWidth:'6',fill:'none',opacity:'.2',strokeLinecap:'round',strokeLinejoin:'round'}));
    const lattr={d,stroke:col,strokeWidth:isSel?'3.5':'2.2',fill:'none',strokeLinecap:'round',strokeLinejoin:'round','marker-end':`url(#${cid})`};
    if(isHL)lattr.filter='url(#glow)';
    svg.appendChild(mkel('path',lattr));

    const mid=ptMid(pts),len=cLen(c).toFixed(2);
    if(showLbl||showLen){
      let l1='';
      if(showLbl)l1+=c.kabelnr;
      if(showLbl&&showLen)l1+='  ';
      if(showLen)l1+=len+'m';
      if(l1){
        const bw=l1.length*5.8+8;
        svg.appendChild(mkel('rect',{x:mid.x-bw/2,y:mid.y-12,width:bw,height:14,rx:'3',fill:'#0a1420',opacity:'.92'}));
        const t=mkel('text',{x:mid.x,y:mid.y-1,fill:col,'font-size':'9.5','font-family':'Figtree,sans-serif','font-weight':'600','text-anchor':'middle'});
        t.textContent=l1;svg.appendChild(t);
      }
      if(showLbl&&c.kabeltype){
        const bw2=c.kabeltype.length*4.8+6;
        svg.appendChild(mkel('rect',{x:mid.x-bw2/2,y:mid.y+2,width:bw2,height:12,rx:'3',fill:'#0a1420',opacity:'.82'}));
        const t2=mkel('text',{x:mid.x,y:mid.y+11,fill:col,'font-size':'8','font-family':'Figtree,sans-serif','text-anchor':'middle',opacity:'.88'});
        t2.textContent=c.kabeltype;svg.appendChild(t2);
      }
    }
    if(showFT){
      const from=elements.find(e=>e.id===c.fromId),to=elements.find(e=>e.id===c.toId);
      if(from)drawEndTag(svg,pts[0],'↑'+from.label,col);
      if(to)drawEndTag(svg,pts[pts.length-1],'↓'+to.label,col);
    }
    if(isSel){
      // show waypoint handles - always visible when selected
      (c.wpts||[]).forEach((wp,wi)=>{
        const wh=mkel('circle',{cx:wp.x,cy:wp.y,r:'7',fill:'#1a2e4c',stroke:col,strokeWidth:'2',opacity:'.95',style:'cursor:grab'});
        svg.appendChild(wh);
        // small cross inside
        svg.appendChild(mkel('line',{x1:wp.x-3,y1:wp.y,x2:wp.x+3,y2:wp.y,stroke:col,strokeWidth:'1.5'}));
        svg.appendChild(mkel('line',{x1:wp.x,y1:wp.y-3,x2:wp.x,y2:wp.y+3,stroke:col,strokeWidth:'1.5'}));
      });
    }
  });

  // cable preview
  if(mode==='cable'&&cablePend&&prevPt){
    const from=elements.find(e=>e.id===cablePend.fromId);
    if(from){
      const all=[{x:from.x,y:from.y},...cablePend.pts.slice(1),prevPt];
      const d=all.map((p,i)=>(i===0?`M${p.x} ${p.y}`:`L${p.x} ${p.y}`)).join(' ');
      svg.appendChild(mkel('path',{d,stroke:'#fff',strokeWidth:'1.5',fill:'none',strokeDasharray:'6 4',opacity:'.45',strokeLinecap:'round'}));
      let l=0;for(let i=1;i<all.length;i++)l+=Math.hypot(all[i].x-all[i-1].x,all[i].y-all[i-1].y);
      const t=mkel('text',{x:prevPt.x+8,y:prevPt.y-6,fill:'#fff','font-size':'10','font-family':'Figtree,sans-serif',opacity:'.7'});
      t.textContent=(l*scale).toFixed(2)+'m';svg.appendChild(t);
    }
  }

  // elements
  elements.forEach(el=>{
    const isSel=selectedId===el.id;
    const isHL=highlightId===el.id;
    const circ=circuits.find(c=>c.id===el.circuit);
    const col=circ?circ.color:'#fff';
    const rot=el.rotation||0;
    const g=mkel('g',{transform:`translate(${el.x},${el.y}) rotate(${rot})`,style:'cursor:pointer'});
    if(isHL) g.appendChild(mkel('circle',{r:'30',fill:'none',stroke:'#fff',strokeWidth:'2.5',opacity:'.9',filter:'url(#glow)'}));
    else if(isSel) g.appendChild(mkel('circle',{r:'26',fill:'none',stroke:'#fff',strokeWidth:'1.8',strokeDasharray:'4 3',opacity:'.7'}));
    g.appendChild(mkel('circle',{r:'22',fill:'none',stroke:col,strokeWidth:'1.2',opacity:'.3'}));
    drawSym(g,el.type,col);
    svg.appendChild(g);
    // label outside rotation (always horizontal)
    if(showRef){
      const bw=el.label.length*6.5+6;
      const labelG=mkel('g',{transform:`translate(${el.x},${el.y})`});
      labelG.appendChild(mkel('rect',{x:-bw/2,y:21,width:bw,height:13,rx:'3',fill:'#0a1420',opacity:'.92'}));
      const t=mkel('text',{x:'0',y:'31',fill:col,'font-size':'9.5','font-family':'Figtree,sans-serif','font-weight':'700','text-anchor':'middle'});
      t.textContent=el.label;labelG.appendChild(t);
      // hoogte badge
      if(el.hoogte){
        const hw=el.hoogte.length*5+8;
        labelG.appendChild(mkel('rect',{x:-hw/2,y:35,width:hw,height:11,rx:'3',fill:'#1a2e4c',opacity:'.9'}));
        const th=mkel('text',{x:'0',y:'44',fill:col,'font-size':'8','font-family':'Figtree,sans-serif','text-anchor':'middle',opacity:'.85'});
        th.textContent='↕'+el.hoogte+'m';labelG.appendChild(th);
      }
      svg.appendChild(labelG);
    }
  });

  // ghost
  if(mode==='place'&&placeType){
    const g=mkel('g',{transform:`translate(${ghostX},${ghostY})`,opacity:'.4',style:'pointer-events:none'});
    drawSym(g,placeType,'#fff');svg.appendChild(g);
  }

  renderCircuits();updateStatus();
}

function drawEndTag(svg,pt,text,col){
  const bw=text.length*4.5+6;
  svg.appendChild(mkel('rect',{x:pt.x+4,y:pt.y-10,width:bw,height:12,rx:'2',fill:'#0a1420',opacity:'.82'}));
  const t=mkel('text',{x:pt.x+7,y:pt.y,fill:col,'font-size':'8','font-family':'Figtree,sans-serif',opacity:'.9'});
  t.textContent=text;svg.appendChild(t);
}
function ptMid(pts){
  let tot=0;
  for(let i=1;i<pts.length;i++)tot+=Math.hypot(pts[i].x-pts[i-1].x,pts[i].y-pts[i-1].y);
  let acc=0,h=tot/2;
  for(let i=1;i<pts.length;i++){
    const seg=Math.hypot(pts[i].x-pts[i-1].x,pts[i].y-pts[i-1].y);
    if(acc+seg>=h){const t=(h-acc)/seg;return{x:pts[i-1].x+(pts[i].x-pts[i-1].x)*t,y:pts[i-1].y+(pts[i].y-pts[i-1].y)*t};}
    acc+=seg;
  }
  return pts[Math.floor(pts.length/2)];
}
function mkel(tag,attrs={}){
  const e=document.createElementNS('http://www.w3.org/2000/svg',tag);
  Object.entries(attrs).forEach(([k,v])=>e.setAttribute(k,v));
  return e;
}

// ── SYMBOLS ───────────────────────────────────────────────────────────────────
function symSVG(type,sz){
  if(customTypes[type]){
    const icon=customTypes[type].icon||'?';
    return `<svg viewBox="0 0 30 30" width="${sz}" height="${sz}" xmlns="http://www.w3.org/2000/svg"><circle cx="15" cy="15" r="12" fill="#1a2040" stroke="#aa55ff" stroke-width="2"/><text x="15" y="21" text-anchor="middle" font-size="14" font-family="sans-serif">${icon}</text></svg>`;
  }
  return `<svg viewBox="0 0 30 30" width="${sz}" height="${sz}" xmlns="http://www.w3.org/2000/svg">${symParts(type)}</svg>`;
}
function drawSym(g,type,col){
  if(customTypes[type]){
    const icon=customTypes[type].icon||'?';
    g.appendChild(mkel('circle',{r:'12',fill:'#1a2040',stroke:col,strokeWidth:'2',cx:'0',cy:'0'}));
    const t=mkel('text',{x:'0',y:'6','text-anchor':'middle','font-size':'14','font-family':'sans-serif'});
    t.textContent=icon;g.appendChild(t);
    return;
  }
  const tmp=mkel('g');tmp.innerHTML=symParts(type);
  tmp.setAttribute('transform','translate(-15,-15)');
  g.appendChild(tmp);
}
function symParts(type){
  switch(type){
    case 'kast': return`<rect x="3" y="4" width="24" height="22" rx="2" fill="#1a2e4c" stroke="#d4ff00" stroke-width="2"/><line x1="3" y1="10" x2="27" y2="10" stroke="#d4ff00" stroke-width="1.5"/><rect x="6" y="13" width="7" height="4" rx="1" fill="#d4ff00" opacity=".7"/><rect x="6" y="19" width="7" height="4" rx="1" fill="#d4ff00" opacity=".7"/><rect x="16" y="13" width="8" height="10" rx="1" fill="none" stroke="#d4ff00" stroke-width="1.2" opacity=".6"/>`;
    case 'doos': return`<circle cx="15" cy="15" r="11" fill="#0f1a28" stroke="#22ddff" stroke-width="2"/><line x1="9" y1="9" x2="21" y2="21" stroke="#22ddff" stroke-width="2"/><line x1="21" y1="9" x2="9" y2="21" stroke="#22ddff" stroke-width="2"/>`;
    case 'lamp': return`<circle cx="15" cy="15" r="11" fill="#1a1500" stroke="#ffaa22" stroke-width="2.5"/><circle cx="15" cy="15" r="5" fill="#ffaa22"/>${[...Array(8)].map((_,i)=>{const a=i*Math.PI/4;return`<line x1="${(15+13*Math.cos(a)).toFixed(1)}" y1="${(15+13*Math.sin(a)).toFixed(1)}" x2="${(15+17*Math.cos(a)).toFixed(1)}" y2="${(15+17*Math.sin(a)).toFixed(1)}" stroke="#ffaa22" stroke-width="1.5" opacity=".6"/>`;}).join('')}`;
    // Enkele TL — één buis
