<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Verlichtingsplanner / Zoeker</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Figtree:wght@300;400;500;600&display=swap');
:root{
  --blue:#1a2e4c;--blue2:#1f3a5f;--blue3:#243d6a;
  --green:#d4ff00;--green2:#a8cc00;
  --panel:#0f1a28;--panel2:#131f30;
  --border:#1e3048;--border2:#253a58;
  --text:#dce8f5;--dim:#5a7a99;
  --red:#ff4455;--amber:#ffaa22;--cyan:#22ddff;--purple:#aa55ff;
  --r:5px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Figtree',sans-serif;background:var(--panel);color:var(--text);height:100vh;display:flex;flex-direction:column;overflow:hidden;font-size:13px;}

/* HEADER */
header{background:var(--blue);border-bottom:2px solid var(--green);height:48px;display:flex;align-items:center;gap:5px;padding:0 10px;flex-shrink:0;z-index:200;}
.logo{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:16px;color:var(--text);letter-spacing:.5px;white-space:nowrap;}
.logo b{color:var(--green);}
.hsep{width:1px;height:24px;background:var(--border2);margin:0 3px;flex-shrink:0;}
.hbtn{background:var(--blue2);border:1px solid var(--border2);color:var(--text);padding:4px 9px;border-radius:var(--r);cursor:pointer;font:500 11px 'Figtree',sans-serif;display:flex;align-items:center;gap:4px;transition:.15s;white-space:nowrap;flex-shrink:0;}
.hbtn:hover{background:var(--blue3);border-color:var(--green);}
.hbtn.act{background:var(--green);color:var(--panel);border-color:var(--green);}

/* SEARCH BAR */
.search-wrap{flex:1;min-width:0;max-width:320px;position:relative;}
.search-wrap input{width:100%;background:var(--panel2);border:1px solid var(--border2);color:var(--text);padding:5px 10px 5px 30px;border-radius:var(--r);font:400 12px 'Figtree',sans-serif;outline:none;transition:.15s;}
.search-wrap input:focus{border-color:var(--green);}
.search-wrap input::placeholder{color:var(--dim);}
.search-icon{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(--dim);font-size:13px;pointer-events:none;}
.search-clear{position:absolute;right:8px;top:50%;transform:translateY(-50%);color:var(--dim);cursor:pointer;font-size:14px;display:none;}
.search-clear.show{display:block;}
#searchResults{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--blue2);border:1px solid var(--green);border-radius:var(--r);z-index:500;max-height:280px;overflow-y:auto;display:none;}
#searchResults.show{display:block;}
.sr-item{padding:7px 10px;cursor:pointer;border-bottom:1px solid var(--border);font-size:11px;display:flex;align-items:center;gap:8px;transition:.1s;}
.sr-item:hover{background:var(--blue3);}
.sr-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sr-main{flex:1;}
.sr-sub{font-size:10px;color:var(--dim);}

/* PDF controls */
#pdfControls{display:none;align-items:center;gap:4px;background:var(--panel2);border:1px solid var(--border2);border-radius:var(--r);padding:3px 7px;flex-shrink:0;}
#pdfControls span{font-size:10px;color:var(--dim);}
#pdfControls button{background:var(--blue2);border:1px solid var(--border2);color:var(--text);padding:2px 7px;border-radius:3px;cursor:pointer;font-size:10px;}
#pdfControls button:hover{border-color:var(--green);}
#pdfRenderScale{width:52px;background:var(--panel2);border:1px solid var(--border2);color:var(--text);padding:2px 4px;border-radius:3px;font-size:10px;}
.hcoord{font-size:10px;color:var(--dim);min-width:130px;flex-shrink:0;}

/* BODY */
.body{display:flex;flex:1;overflow:hidden;}

/* LEFT */
aside{width:200px;background:var(--panel2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0;}
.sec{border-bottom:1px solid var(--border);padding:9px;}
.stitle{font-family:'Rajdhani',sans-serif;font-weight:600;font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--green);margin-bottom:7px;}
.pal{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.pitem{background:var(--blue);border:1px solid var(--border2);border-radius:4px;padding:6px 3px;cursor:pointer;text-align:center;transition:.15s;user-select:none;}
.pitem:hover{border-color:var(--green);}
.pitem.act{border-color:var(--green);background:var(--blue3);box-shadow:0 0 0 1px var(--green);}
.psym{width:32px;height:32px;margin:0 auto 3px;display:flex;align-items:center;justify-content:center;}
.psym svg{width:28px;height:28px;}
.plbl{font-size:8.5px;color:var(--dim);line-height:1.3;}
.circ-list{display:flex;flex-direction:column;gap:3px;}
.circ{display:flex;align-items:center;gap:5px;padding:4px 7px;background:var(--blue);border:1px solid var(--border2);border-radius:4px;cursor:pointer;font-size:11px;transition:.15s;}
.circ:hover{border-color:var(--green);}
.circ.act{border-color:var(--green);background:var(--blue3);}
.cdot{width:9px;height:9px;border-radius:50%;flex-shrink:0;cursor:pointer;}
.cname{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ccnt{font-size:9px;color:var(--dim);}
.cbtn{background:none;border:1px dashed var(--border2);color:var(--dim);padding:4px;border-radius:4px;cursor:pointer;font-size:10px;width:100%;transition:.15s;margin-top:5px;}
.cbtn:hover{border-color:var(--green);color:var(--green);}
.fsel,.finp{width:100%;background:var(--blue);border:1px solid var(--border2);color:var(--text);padding:4px 7px;border-radius:4px;font-size:11px;font-family:'Figtree',sans-serif;}
.fsel:focus,.finp:focus{outline:none;border-color:var(--green);}
.frow{margin-bottom:7px;}
.flbl{font-size:9px;color:var(--dim);margin-bottom:2px;text-transform:uppercase;letter-spacing:.4px;}

/* CANVAS */
.cvwrap{flex:1;position:relative;overflow:hidden;background:#09121c;cursor:default;}
.cvwrap.mode-place{cursor:crosshair!important;}
.cvwrap.mode-cable{cursor:crosshair!important;}
.cvwrap.mode-del{cursor:not-allowed!important;}
.cvwrap.mode-drag{cursor:grabbing!important;}
.ortho-badge{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:var(--green);color:var(--panel);padding:3px 10px;border-radius:10px;font-size:10px;font-weight:700;pointer-events:none;z-index:300;display:none;}
.ortho-badge.show{display:block;}
#vp{position:absolute;top:0;left:0;transform-origin:0 0;}
#planCanvas{display:block;max-width:none;user-select:none;pointer-events:none;}
#svg{position:absolute;top:0;left:0;overflow:visible;pointer-events:all;}
#loadOverlay{position:absolute;inset:0;background:rgba(9,18,28,.88);display:none;align-items:center;justify-content:center;flex-direction:column;gap:10px;z-index:20;}
#loadOverlay.show{display:flex;}
.load-spinner{width:34px;height:34px;border:3px solid var(--border2);border-top-color:var(--green);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
#dropzone{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:10;background:#09121c;}
.dropinner{border:2px dashed var(--border2);border-radius:12px;padding:44px 52px;text-align:center;transition:.2s;}
.dropinner.ov{border-color:var(--green);}
.dicon{font-size:52px;margin-bottom:12px;}
.dtitle{font-family:'Rajdhani',sans-serif;font-size:22px;margin-bottom:5px;}
.dsub{font-size:11px;color:var(--dim);margin-bottom:14px;line-height:1.9;}
.dupbtn{display:inline-block;background:var(--green);color:var(--panel);padding:8px 20px;border-radius:5px;font-weight:600;font-size:13px;cursor:pointer;}

/* RIGHT */
.rpanel{width:268px;background:var(--panel2);border-left:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
.rtabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;}
.rtab{flex:1;padding:8px 3px;text-align:center;font-size:9.5px;font-weight:600;text-transform:uppercase;letter-spacing:.7px;cursor:pointer;color:var(--dim);border-bottom:2px solid transparent;transition:.15s;}
.rtab:hover{color:var(--text);}
.rtab.act{color:var(--green);border-bottom-color:var(--green);}
.rcont{flex:1;overflow-y:auto;padding:11px;}
.prop-head{font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:600;color:var(--green);margin-bottom:10px;display:flex;align-items:center;gap:7px;}
.prow{margin-bottom:8px;}
.plbl2{font-size:9.5px;color:var(--dim);margin-bottom:2px;text-transform:uppercase;letter-spacing:.4px;}
.pinp,.psel{width:100%;background:var(--blue);border:1px solid var(--border2);color:var(--text);padding:4px 7px;border-radius:4px;font-size:11px;font-family:'Figtree',sans-serif;}
.pinp:focus,.psel:focus{outline:none;border-color:var(--green);}
.pempty{text-align:center;color:var(--dim);padding:28px 0;font-size:12px;line-height:1.9;}
.pdelbtn{width:100%;background:none;border:1px solid var(--red);color:var(--red);padding:5px;border-radius:4px;cursor:pointer;font-size:11px;margin-top:7px;transition:.15s;}
.pdelbtn:hover{background:var(--red);color:white;}

/* rotation btns */
.rot-row{display:flex;gap:5px;margin-bottom:8px;}
.rot-btn{flex:1;background:var(--blue);border:1px solid var(--border2);color:var(--dim);padding:5px 4px;border-radius:4px;cursor:pointer;font-size:11px;text-align:center;transition:.15s;}
.rot-btn:hover{border-color:var(--green);color:var(--text);}
.rot-btn.act{background:var(--green);color:var(--panel);border-color:var(--green);font-weight:600;}

/* color swatch */
.color-row{display:flex;gap:4px;align-items:center;flex-wrap:wrap;margin-top:3px;}
.cswatch{width:20px;height:20px;border-radius:3px;cursor:pointer;border:2px solid transparent;flex-shrink:0;transition:.1s;}
.cswatch:hover,.cswatch.act{border-color:#fff;}
.cpick{width:28px;height:20px;border-radius:3px;cursor:pointer;border:1px solid var(--border2);padding:0;background:none;}

/* stuklijst */
.stuk-table{width:100%;border-collapse:collapse;font-size:11px;}
.stuk-table th{text-align:left;padding:4px 5px;background:var(--blue);color:var(--dim);font-size:8.5px;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border2);}
.stuk-table td{padding:4px 5px;border-bottom:1px solid var(--border);vertical-align:top;}
.stuk-table tr:hover td{background:var(--blue);}
.stuk-num{font-weight:600;color:var(--green);}
.stuk-section{padding:4px 5px;background:var(--panel);color:var(--dim);font-size:8.5px;text-transform:uppercase;letter-spacing:1px;font-weight:700;}
.xbtn{width:100%;border:none;padding:7px;border-radius:4px;cursor:pointer;font:600 11px 'Figtree',sans-serif;margin-bottom:5px;}
.xbtn-g{background:var(--green);color:var(--panel);}
.xbtn-b{background:var(--blue2);color:var(--text);border:1px solid var(--border2);}

/* HIGHLIGHT on canvas */
.hl-pulse{animation:hlpulse 1.2s ease-in-out 3;}
@keyframes hlpulse{0%,100%{opacity:1;}50%{opacity:.3;}}

footer{height:23px;background:var(--blue);border-top:1px solid var(--border);display:flex;align-items:center;padding:0 10px;gap:14px;flex-shrink:0;font-size:10px;color:var(--dim);}
.sb-mode{color:var(--green);font-weight:600;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--panel);}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
@media print{header,aside,.rpanel,footer{display:none!important;}.body{display:block;}.cvwrap{width:100vw;height:100vh;overflow:visible;}}
</style>
</head>
<body>
<header>
  <div class="logo"><b>Verlichtingsplanner</b> / Zoeker</div>
  <div class="hsep"></div>
  <button class="hbtn act" id="btnSelect" onclick="setMode('select')">▸ Selecteer</button>
  <button class="hbtn" id="btnCable" onclick="startCableMode()">⟶ Kabel (K)</button>
  <button class="hbtn" id="btnDel" onclick="setMode('del')">✕ Verwijder</button>
  <div class="hsep"></div>
  <!-- SEARCH -->
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" id="searchInput" placeholder="Zoek naam, nr, type, kabel..." oninput="doSearch(this.value)" onkeydown="searchKey(event)">
    <span class="search-clear" id="searchClear" onclick="clearSearch()">✕</span>
    <div id="searchResults"></div>
  </div>
  <div class="hsep"></div>
  <button class="hbtn" onclick="saveProject()">💾</button>
  <button class="hbtn" onclick="loadProject()">📂</button>
  <button class="hbtn" onclick="exportCSV()">⬇CSV</button>
  <button class="hbtn" onclick="window.print()">🖨</button>
  <div class="hsep"></div>
  <div id="pdfControls">
    <button onclick="changePage(-1)">◀</button>
    <span id="pdfPageInfo">1/1</span>
    <button onclick="changePage(1)">▶</button>
    <select id="pdfRenderScale" onchange="rerenderPDF()">
      <option value="1.5">1.5x</option>
      <option value="2" selected>2x</option>
      <option value="3">3x</option>
    </select>
  </div>
  <div class="scale-row" style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
    <span style="font-size:10px;color:var(--dim)">1px=</span>
    <input type="number" id="scaleInput" value="0.05" step="0.005" min="0.001" style="width:58px;background:var(--panel2);border:1px solid var(--border2);color:var(--text);padding:3px 6px;border-radius:4px;font-size:10px;" oninput="scale=+this.value||0.05;redraw()">
    <span style="font-size:10px;color:var(--dim)">m</span>
  </div>
  <div class="hcoord" id="coordDisplay">x:0.00m y:0.00m</div>
</header>

<div class="body">
<!-- LEFT -->
<aside>
  <div class="sec">
    <div class="stitle">Armaturen & elementen</div>
    <div class="pal" id="palette"></div>
    <button class="cbtn" style="margin-top:5px" onclick="addCustomType()">+ Nieuw type toevoegen</button>
  </div>
  <div class="sec">
    <div class="stitle">Kringen</div>
    <div class="circ-list" id="circuitList"></div>
    <button class="cbtn" onclick="addCircuit()">+ Kring toevoegen</button>
  </div>
  <div class="sec">
    <div class="stitle">Kabeltype</div>
    <div class="frow">
      <select class="fsel" id="cableTypeSelect">
        <option>NYM-J 3x1.5mm²</option>
        <option>NYM-J 3x2.5mm²</option>
        <option>NYM-J 5x1.5mm²</option>
        <option>NYM-J 5x2.5mm²</option>
        <option>XVB 3G1.5mm²</option>
        <option>XVB 3G2.5mm²</option>
        <option>XVB 5G1.5mm²</option>
        <option>XVB 5G2.5mm²</option>
        <option>VVMB 3x1.5mm²</option>
        <option>VVMB 5x1.5mm²</option>
        <option value="__custom">Aangepast...</option>
      </select>
    </div>
    <div id="customRow" style="display:none;margin-top:4px">
      <input class="finp" id="customCable" placeholder="Bv. EXVB 2x1.5mm²">
    </div>
  </div>
  <div class="sec">
    <div class="stitle">Weergave</div>
    <div style="display:flex;flex-direction:column;gap:5px">
      <label style="display:flex;align-items:center;gap:5px;font-size:11px"><input type="checkbox" id="showLabels" checked onchange="redraw()"> Kabellabels & type</label>
      <label style="display:flex;align-items:center;gap:5px;font-size:11px"><input type="checkbox" id="showLengths" checked onchange="redraw()"> Kabellengtes</label>
      <label style="display:flex;align-items:center;gap:5px;font-size:11px"><input type="checkbox" id="showRefs" checked onchange="redraw()"> Referenties</label>
      <label style="display:flex;align-items:center;gap:5px;font-size:11px"><input type="checkbox" id="showFromTo" checked onchange="redraw()"> Van/Naar labels</label>
    </div>
    <div style="margin-top:8px">
      <div class="flbl">Plan transparantie</div>
      <input type="range" min="0" max="100" value="100" style="width:100%" oninput="document.getElementById('planCanvas').style.opacity=this.value/100">
    </div>
  </div>
</aside>

<!-- CANVAS -->
<div class="cvwrap" id="cvwrap"
  onmousedown="cvDown(event)" onmousemove="cvMove(event)" onmouseup="cvUp(event)"
  onwheel="cvWheel(event)" ondragover="event.preventDefault()" ondrop="doDrop(event)">
<div class="ortho-badge" id="orthoBadge">⊢ Ortho-snap (Shift)</div>
  <div id="dropzone">
    <div class="dropinner" id="dropinner">
      <div class="dicon">📐</div>
      <div class="dtitle">Grondplan uploaden</div>
      <div class="dsub">Sleep een <strong>PDF</strong> of afbeelding (PNG/JPG)<br>PDF wordt op hoge resolutie gerenderd</div>
      <label class="dupbtn">Bestand kiezen
        <input type="file" accept="image/*,application/pdf" style="display:none" onchange="loadFile(this)">
      </label>
    </div>
  </div>
  <div id="loadOverlay">
    <div class="load-spinner"></div>
    <div style="font-size:12px;color:var(--dim)" id="loadTxt">Laden...</div>
    <div style="font-size:11px;color:var(--green)" id="loadProg"></div>
  </div>
  <div id="vp">
    <canvas id="planCanvas" style="display:none"></canvas>
    <svg id="svg" xmlns="http://www.w3.org/2000/svg" style="position:absolute;top:0;left:0;overflow:visible"></svg>
  </div>
</div>

<!-- RIGHT -->
<div class="rpanel">
  <div class="rtabs">
    <div class="rtab act" id="rt-props" onclick="showRTab('props')">Eigenschappen</div>
    <div class="rtab" id="rt-list" onclick="showRTab('list')">Elementen</div>
    <div class="rtab" id="rt-stuk" onclick="showRTab('stuk')">Stuklijst</div>
  </div>
  <div class="rcont" id="rProps"><div class="pempty">Klik op een element<br>of kabel om te bewerken</div></div>
  <div class="rcont" id="rList" style="display:none"></div>
  <div class="rcont" id="rStuk" style="display:none"></div>
</div>
</div>

<footer>
  <span>Modus: <span class="sb-mode" id="sbMode">Selecteren</span></span>
  <span id="sbEl">0 elementen</span>
  <span id="sbKb">0 kabels</span>
  <span id="sbM">0.0 m</span>
  <span id="sbPdf" style="color:var(--cyan)"></span>
</footer>

<script>
pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

// ── STATE ─────────────────────────────────────────────────────────────────────
let elements=[], cables=[], circuits=[
  {id:'c1',name:'Kring 1',kabelnr:'',color:'#d4ff00'},
  {id:'c2',name:'Kring 2',kabelnr:'',color:'#22ddff'},
  {id:'c3',name:'Kring 3',kabelnr:'',color:'#ff8833'},
];
let activeCircuit='c1', selectedId=null, highlightId=null;
let nextId=1, nextKb=1;
let nextRef={kast:1,doos:1,lamp:1,tl1:1,tl2:1,extl:1,exled:1,strip:1,nood:1,buiten:1,schakelaar:1};
// per-circuit per-type counters for auto-labeling
let circTypeCounters={};
let scale=0.05;
let vx=60,vy=60,vzoom=1,isPan=false,panSX=0,panSY=0;
let planW=0,planH=0;
let mode='select',placeType='',cablePend=null,ghostX=0,ghostY=0,prevPt=null;
// drag state — elements
let isDragging=false,dragElemId=null,dragOffX=0,dragOffY=0,dragMoved=false;
// drag state — cable waypoints
let isDragWpt=false,dragWptCableId=null,dragWptIdx=-1;
// orthogonal cable snap (Shift key)
let orthoSnap=false;
// last placed label per circuit+type for auto-increment
let lastPlacedLabel={};
// custom component types (user-defined)
let customTypes={}; // id -> {lbl,icon,ref,cat:'arm'}
let paletteOrder=['kast','doos','lamp','tl1','tl2','extl','exled','strip','nood','buiten','schakelaar'];
let pdfDoc=null,pdfPage=1,pdfTotalPages=1,pdfArrayBuffer=null;
const HITRAD=20;

// Preset cable colors
const CABLE_COLORS=['#d4ff00','#22ddff','#ff8833','#ff4455','#aa55ff','#55ff88','#ff55aa','#ffffff','#ffdd00','#ff8888'];
const CIRCUIT_COLORS=['#d4ff00','#22ddff','#ff8833','#ff4455','#aa55ff','#55ff88','#ff55aa','#ffdd00'];

// TYPEINFO — extended with new fixture types
const TYPEINFO={
  kast:    {lbl:'Verdeelkast',     icon:'🔌', ref:'K',   cat:'infra'},
  doos:    {lbl:'Aansluitdoos',    icon:'⭕', ref:'AD',  cat:'infra'},
  lamp:    {lbl:'Downlight/Spot',  icon:'💡', ref:'DL',  cat:'arm'},
  tl1:     {lbl:'Enkele TL',       icon:'▬',  ref:'TL1', cat:'arm'},
  tl2:     {lbl:'Dubbele TL',      icon:'▬▬', ref:'TL2', cat:'arm'},
  extl:    {lbl:'EX Armatuur TL',  icon:'⚠',  ref:'EXT', cat:'arm'},
  exled:   {lbl:'EX LED Armatuur', icon:'⚡', ref:'EXL', cat:'arm'},
  strip:   {lbl:'LED strip',       icon:'〰',  ref:'LS',  cat:'arm'},
  nood:    {lbl:'Noodverlichting', icon:'🚨', ref:'NV',  cat:'arm'},
  buiten:  {lbl:'Buitenverlichting',icon:'🌐',ref:'BV',  cat:'arm'},
  schakelaar:{lbl:'Schakelaar',    icon:'🔘', ref:'SCH', cat:'infra'},
};
// Dynamic merged type info (builtin + user custom types)
function allTypeInfo(){return Object.assign({},TYPEINFO,customTypes);}
function getPaletteOrder(){return [...paletteOrder,...Object.keys(customTypes)];}

// ── INIT ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  buildPalette(); renderCircuits(); redraw();
  document.addEventListener('keydown',onKey);
  document.getElementById('cableTypeSelect').addEventListener('change',function(){
    document.getElementById('customRow').style.display=this.value==='__custom'?'block':'none';
  });
  const di=document.getElementById('dropinner');
  di.addEventListener('dragover',e=>{e.preventDefault();di.classList.add('ov');});
  di.addEventListener('dragleave',()=>di.classList.remove('ov'));
  di.addEventListener('drop',e=>{e.preventDefault();di.classList.remove('ov');handleFile(e.dataTransfer.files[0]);});
  document.addEventListener('click',e=>{
    if(!e.target.closest('.search-wrap')) closeSearch();
  });
});

// ── PALETTE ───────────────────────────────────────────────────────────────────
function buildPalette(){
  const TI=allTypeInfo();
  const order=getPaletteOrder();
  document.getElementById('palette').innerHTML=order.map(t=>`
    <div class="pitem" id="pi-${t}" onclick="pickPlace('${t}')" title="${TI[t]?.lbl||t}">
      <div class="psym">${symSVG(t,26)}</div>
      <div class="plbl">${TI[t]?.lbl||t}</div>
    </div>`).join('');
}

// ── CUSTOM TYPES ──────────────────────────────────────────────────────────────
function addCustomType(){
  const lbl=prompt('Naam nieuw type (bv. Paneel LED):','');
  if(!lbl)return;
  const icon=prompt('Icoon (1 emoji, bv. 🔦):','🔦')||'🔦';
  const ref=prompt('Referentieprefix (bv. PL):','CU')||'CU';
  const id='ct_'+Math.random().toString(36).slice(2,7);
  customTypes[id]={lbl,icon,ref,cat:'arm'};
  paletteOrder.push(id);
  // init ref counter
  nextRef[id]=1;
  buildPalette();
}
function removeCustomType(id){
  if(!confirm('Type "'+customTypes[id]?.lbl+'" verwijderen uit palet?'))return;
  delete customTypes[id];
  paletteOrder=paletteOrder.filter(x=>x!==id);
  buildPalette();
}
function loadFile(inp){if(inp.files[0])handleFile(inp.files[0]);}
function doDrop(e){e.preventDefault();if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);}
function handleFile(f){
  if(!f)return;
  if(f.type==='application/pdf'||f.name.toLowerCase().endsWith('.pdf')) loadPDF(f);
  else loadImage(f);
}
function loadImage(file){
  const r=new FileReader();
  r.onload=ev=>{
    const img=new Image();
    img.onload=()=>{
      const c=document.getElementById('planCanvas');
      c.width=img.naturalWidth; c.height=img.naturalHeight;
      c.getContext('2d').drawImage(img,0,0);
      planW=c.width; planH=c.height;
      showPlan();
    };
    img.src=ev.target.result;
  };
  r.readAsDataURL(file);
}
function loadPDF(file){
  showLoad('PDF inladen...','');
  const r=new FileReader();
  r.onload=async ev=>{
    try{
      pdfArrayBuffer=ev.target.result;
      const task=pdfjsLib.getDocument({data:pdfArrayBuffer,enableXfa:true});
      task.onProgress=p=>{if(p.total>0)document.getElementById('loadProg').textContent=Math.round(p.loaded/p.total*100)+'%';};
      pdfDoc=await task.promise;
      pdfTotalPages=pdfDoc.numPages; pdfPage=1;
      document.getElementById('pdfControls').style.display='flex';
      updatePDFCtrl();
      await renderPDFPage(pdfPage);
    }catch(err){hideLoad();alert('PDF fout:\n'+err.message);}
  };
  r.readAsArrayBuffer(file);
}
async function renderPDFPage(n){
  showLoad('Pagina '+n+' renderen...','');
  try{
    const page=await pdfDoc.getPage(n);
    const rs=parseFloat(document.getElementById('pdfRenderScale').value)||2;
    const vp=page.getViewport({scale:rs});
    const c=document.getElementById('planCanvas');
    c.width=Math.floor(vp.width); c.height=Math.floor(vp.height);
    const ctx=c.getContext('2d');
    ctx.fillStyle='#fff'; ctx.fillRect(0,0,c.width,c.height);
    await page.render({canvasContext:ctx,viewport:vp}).promise;
    planW=c.width; planH=c.height;
    document.getElementById('sbPdf').textContent=`PDF p.${n}/${pdfTotalPages} · ${rs}x`;
    showPlan();
  }catch(err){hideLoad();alert('Render fout: '+err.message);}
}
async function rerenderPDF(){if(pdfDoc)await renderPDFPage(pdfPage);}
async function changePage(d){
  if(!pdfDoc)return;
  const np=pdfPage+d;
  if(np<1||np>pdfTotalPages)return;
  pdfPage=np; updatePDFCtrl();
  await renderPDFPage(pdfPage);
}
function updatePDFCtrl(){document.getElementById('pdfPageInfo').textContent=pdfPage+'/'+pdfTotalPages;}
function showLoad(t,p){document.getElementById('loadOverlay').classList.add('show');document.getElementById('loadTxt').textContent=t;document.getElementById('loadProg').textContent=p;}
function hideLoad(){document.getElementById('loadOverlay').classList.remove('show');}
function showPlan(){
  const c=document.getElementById('planCanvas');
  c.style.display='block'; c.style.width=planW+'px'; c.style.height=planH+'px';
  document.getElementById('svg').setAttribute('width',planW);
  document.getElementById('svg').setAttribute('height',planH);
  document.getElementById('dropzone').style.display='none';
  const w=document.getElementById('cvwrap');
  const sc=Math.min((w.clientWidth-60)/planW,(w.clientHeight-60)/planH,1);
  vzoom=sc; vx=(w.clientWidth-planW*sc)/2; vy=(w.clientHeight-planH*sc)/2;
  applyVP(); hideLoad(); redraw();
}

// ── VIEWPORT ──────────────────────────────────────────────────────────────────
function applyVP(){document.getElementById('vp').style.transform=`translate(${vx}px,${vy}px) scale(${vzoom})`;}
function toWorld(cx,cy){return{x:(cx-vx)/vzoom,y:(cy-vy)/vzoom};}
function cvWheel(e){
  e.preventDefault();
  const r=document.getElementById('cvwrap').getBoundingClientRect();
  const mx=e.clientX-r.left,my=e.clientY-r.top;
  const f=e.deltaY<0?1.15:1/1.15;
  const nz=Math.max(0.04,Math.min(14,vzoom*f));
  vx=mx-(mx-vx)*nz/vzoom; vy=my-(my-vy)*nz/vzoom; vzoom=nz;
  applyVP();
}

// ── MOUSE ─────────────────────────────────────────────────────────────────────
function cvDown(e){
  if(e.button===1||(e.button===0&&e.altKey)){isPan=true;panSX=e.clientX-vx;panSY=e.clientY-vy;return;}
  if(e.button!==0)return;
  const r=document.getElementById('cvwrap').getBoundingClientRect();
  const w=toWorld(e.clientX-r.left,e.clientY-r.top);

  if(mode==='place'){placeElem(w.x,w.y);return;}

  if(mode==='cable'){
    if(!cablePend){
      const h=hitElem(w.x,w.y);
      if(h)cablePend={fromId:h.id,pts:[{x:w.x,y:w.y}]};
    } else {
      const snapped=orthoSnap?snapOrtho(cablePend.pts[cablePend.pts.length-1]||{x:w.x,y:w.y},w):w;
      const h=hitElem(snapped.x,snapped.y);
      if(h&&h.id!==cablePend.fromId)finishCable(h.id);
      else cablePend.pts.push(snapped);
    }
    redraw();return;
  }

  if(mode==='del'){
    const h=hitElem(w.x,w.y);if(h){delElem(h.id);return;}
    const k=hitCable(w.x,w.y);if(k){delCable(k.id);return;}
    return;
  }

  // SELECT — check waypoints first, then elements, then cables
  if(selectedId&&selectedId.startsWith('cable:')){
    // Only check waypoints when that cable is selected
    const wh=hitWaypoint(w.x,w.y);
    if(wh){
      isDragWpt=true; dragWptCableId=wh.cable.id; dragWptIdx=wh.idx;
      document.getElementById('cvwrap').classList.add('mode-drag');
      return;
    }
  }
  const h=hitElem(w.x,w.y);
  if(h){
    selectedId=h.id;
    isDragging=true; dragElemId=h.id;
    dragOffX=w.x-h.x; dragOffY=w.y-h.y; dragMoved=false;
    document.getElementById('cvwrap').classList.add('mode-drag');
    renderProps();redraw();return;
  }
  const k=hitCable(w.x,w.y);
  if(k){selectedId='cable:'+k.id;renderProps();redraw();return;}
  selectedId=null;renderProps();redraw();
  isPan=true;panSX=e.clientX-vx;panSY=e.clientY-vy;
}

function cvMove(e){
  const r=document.getElementById('cvwrap').getBoundingClientRect();
  const raw=toWorld(e.clientX-r.left,e.clientY-r.top);
  orthoSnap=e.shiftKey;
  document.getElementById('orthoBadge').classList.toggle('show',orthoSnap&&mode==='cable'&&!!cablePend);
  let w=raw;
  if(orthoSnap&&mode==='cable'&&cablePend&&cablePend.pts.length>0){
    const last=cablePend.pts[cablePend.pts.length-1];
    w=snapOrtho(last,raw);
  }
  ghostX=w.x;ghostY=w.y;prevPt=w;
  document.getElementById('coordDisplay').textContent=`x:${(raw.x*scale).toFixed(2)}m y:${(raw.y*scale).toFixed(2)}m`;

  if(isDragWpt&&dragWptCableId!==null){
    const c=cables.find(x=>x.id===dragWptCableId);
    if(c&&c.wpts&&c.wpts[dragWptIdx]!==undefined){
      c.wpts[dragWptIdx]={x:raw.x,y:raw.y};
    }
    redraw();return;
  }
  if(isDragging&&dragElemId){
    const el=elements.find(x=>x.id===dragElemId);
    if(el){el.x=raw.x-dragOffX; el.y=raw.y-dragOffY; dragMoved=true;}
    redraw();return;
  }
  if(isPan){vx=e.clientX-panSX;vy=e.clientY-panSY;applyVP();}
  if(mode==='place'||mode==='cable')redraw();
}

function cvUp(e){
  if(isDragWpt){
    isDragWpt=false; dragWptCableId=null; dragWptIdx=-1;
    document.getElementById('cvwrap').classList.remove('mode-drag');
    redraw();return;
  }
  if(isDragging){
    isDragging=false;
    document.getElementById('cvwrap').classList.remove('mode-drag');
    if(dragMoved)renderElemList();
    dragElemId=null;dragMoved=false;
    redraw();return;
  }
  if(isPan)isPan=false;
}
// Snap point to nearest 45° from anchor
function snapOrtho(anchor,pt){
  const dx=pt.x-anchor.x, dy=pt.y-anchor.y;
  const len=Math.hypot(dx,dy);
  if(len<1)return pt;
  const angle=Math.atan2(dy,dx);
  const snapped=Math.round(angle/(Math.PI/4))*(Math.PI/4);
  return{x:anchor.x+len*Math.cos(snapped), y:anchor.y+len*Math.sin(snapped)};
}

// ── HIT TEST ──────────────────────────────────────────────────────────────────
function hitElem(wx,wy){
  for(let i=elements.length-1;i>=0;i--){
    const e=elements[i];
    if(Math.hypot(wx-e.x,wy-e.y)<HITRAD)return e;
  }
  return null;
}
function hitWaypoint(wx,wy){
  // Returns {cable,idx} if within 10px of a waypoint, else null
  for(const c of cables){
    if(!c.wpts||!c.wpts.length)continue;
    for(let i=0;i<c.wpts.length;i++){
      if(Math.hypot(wx-c.wpts[i].x,wy-c.wpts[i].y)<12)
        return{cable:c,idx:i};
    }
  }
  return null;
}
  for(const c of cables){
    const pts=cPts(c);
    for(let i=0;i<pts.length-1;i++)
      if(segD(wx,wy,pts[i].x,pts[i].y,pts[i+1].x,pts[i+1].y)<9)return c;
  }
  return null;
}
function segD(px,py,ax,ay,bx,by){
  const dx=bx-ax,dy=by-ay,t=dx||dy?Math.max(0,Math.min(1,((px-ax)*dx+(py-ay)*dy)/(dx*dx+dy*dy))):0;
  return Math.hypot(px-(ax+t*dx),py-(ay+t*dy));
}
function cPts(c){
  const f=elements.find(e=>e.id===c.fromId),t=elements.find(e=>e.id===c.toId);
  if(!f||!t)return[];
  return [{x:f.x,y:f.y},...(c.wpts||[]),{x:t.x,y:t.y}];
}
function cLen(c){
  const pts=cPts(c);let l=0;
  for(let i=1;i<pts.length;i++)l+=Math.hypot(pts[i].x-pts[i-1].x,pts[i].y-pts[i-1].y);
  return l*scale;
}

// ── PLACEMENT ─────────────────────────────────────────────────────────────────
function placeElem(wx,wy){
  const t=placeType, id='e'+nextId++;
  const TI=allTypeInfo();
  const circ=circuits.find(c=>c.id===activeCircuit);
  const typeRef=TI[t]?.ref||'X';
  const lk=activeCircuit+'_'+t; // key for last-label tracking

  let label;
  const last=lastPlacedLabel[lk];
  if(last){
    // Try to increment the trailing number in the last label
    // Works for: "106.1" → "106.2", "TL1.03" → "TL1.04", "K01" → "K02"
    label=incrementLabel(last);
  } else if(circ&&circ.kabelnr){
    // per-circuit per-type counter
    circTypeCounters[lk]=(circTypeCounters[lk]||0)+1;
    label=circ.kabelnr+'.'+typeRef+'.'+String(circTypeCounters[lk]).padStart(2,'0');
  } else {
    const rn=nextRef[t]++;
    label=typeRef+String(rn).padStart(2,'0');
  }
  lastPlacedLabel[lk]=label;

  elements.push({id,type:t,x:wx,y:wy,label,ref:label,circuit:activeCircuit,
    watt:0,notes:'',armatuurtype:'',kasttype:'',rotation:0,hoogte:''});
  selectedId=id;renderProps();renderElemList();updateStatus();redraw();
}

// Increment trailing number in a label string
// "106.1" → "106.2", "AB.03" → "AB.04", "TL01" → "TL02"
function incrementLabel(lbl){
  const m=lbl.match(/^(.*?)(\d+)([^\d]*)$/);
  if(!m)return lbl+'_2';
  const prefix=m[1], num=parseInt(m[2]), suffix=m[3];
  const padded=String(num+1).padStart(m[2].length,'0');
  return prefix+padded+suffix;
}

// When user manually edits a label, update the tracker for that element's circuit+type
function onLabelChange(elemId,newVal){
  const el=elements.find(e=>e.id===elemId);if(!el)return;
  el.label=newVal;
  const lk=el.circuit+'_'+el.type;
  lastPlacedLabel[lk]=newVal;
  redraw();
}
function getCableType(){
  const s=document.getElementById('cableTypeSelect');
  return s.value==='__custom'?(document.getElementById('customCable').value||'Onbekend'):s.value;
}
function startCableMode(){cablePend=null;setMode('cable');}
function finishCable(toId){
  if(!cablePend)return;
  const circ=circuits.find(c=>c.id===activeCircuit);
  const id='kb'+nextKb++;
  cables.push({id,fromId:cablePend.fromId,toId,wpts:cablePend.pts.slice(1),
    kabeltype:getCableType(),kabelnr:'KB'+String(nextKb-1).padStart(2,'0'),
    color:circ?circ.color:'#d4ff00',circuit:activeCircuit,notes:''});
  cablePend=null;
  selectedId='cable:'+id;
  renderProps();renderElemList();updateStatus();redraw();
}
function delElem(id){
  elements=elements.filter(e=>e.id!==id);
  cables=cables.filter(c=>c.fromId!==id&&c.toId!==id);
  if(selectedId===id)selectedId=null;
  renderProps();renderElemList();updateStatus();redraw();
}
function delCable(id){
  cables=cables.filter(c=>c.id!==id);
  if(selectedId==='cable:'+id)selectedId=null;
  renderProps();updateStatus();redraw();
}

// ── MODE ──────────────────────────────────────────────────────────────────────
function setMode(m){
  mode=m;
  if(m!=='place'){placeType='';document.querySelectorAll('.pitem').forEach(p=>p.classList.remove('act'));}
  const w=document.getElementById('cvwrap');
  w.className='cvwrap';
  if(m==='place')w.classList.add('mode-place');
  if(m==='cable')w.classList.add('mode-cable');
  if(m==='del')w.classList.add('mode-del');
  ['btnSelect','btnCable','btnDel'].forEach(b=>document.getElementById(b)?.classList.remove('act'));
  if(m==='select')document.getElementById('btnSelect').classList.add('act');
  if(m==='cable')document.getElementById('btnCable').classList.add('act');
  if(m==='del')document.getElementById('btnDel').classList.add('act');
  const mn={select:'Selecteren',place:'Element plaatsen',cable:cablePend?'Kabel — kies eindpunt':'Kabel — kies startpunt',del:'Verwijderen'};
  document.getElementById('sbMode').textContent=mn[m]||m;
}
function pickPlace(t){
  placeType=t;setMode('place');
  document.querySelectorAll('.pitem').forEach(p=>p.classList.remove('act'));
  document.getElementById('pi-'+t)?.classList.add('act');
}
function onKey(e){
  if(e.target.tagName==='INPUT'||e.target.tagName==='SELECT')return;
  if(e.key==='Escape'){cablePend=null;setMode('select');redraw();}
  if(e.key==='s'||e.key==='S')setMode('select');
  if(e.key==='k'||e.key==='K')startCableMode();
  if(e.key==='ArrowLeft')changePage(-1);
  if(e.key==='ArrowRight')changePage(1);
  if(e.key==='r'||e.key==='R'){
    if(selectedId&&!selectedId.startsWith('cable:')){
      const el=elements.find(x=>x.id===selectedId);
      if(el){el.rotation=(el.rotation+90)%360;renderProps();redraw();}
    }
  }
  if((e.key==='Delete'||e.key==='Backspace')&&selectedId){
    if(selectedId.startsWith('cable:'))delCable(selectedId.replace('cable:',''));
    else delElem(selectedId);
  }
}

// ── CIRCUITS ──────────────────────────────────────────────────────────────────
function addCircuit(){
  const name=prompt('Naam kring (bv. Bureel verdieping):','Kring '+(circuits.length+1));
  if(!name)return;
  const kabelnr=prompt('Kabelnummer automaat (bv. 106-750V):\n(leeg laten = geen prefix)','');
  const id='c_'+Math.random().toString(36).slice(2,7);
  circuits.push({id,name,kabelnr:kabelnr||'',color:CIRCUIT_COLORS[circuits.length%CIRCUIT_COLORS.length]});
  renderCircuits();
}
function renderCircuits(){
  document.getElementById('circuitList').innerHTML=circuits.map(c=>`
    <div class="circ ${c.id===activeCircuit?'act':''}" onclick="activeCircuit='${c.id}';renderCircuits()">
      <div class="cdot" style="background:${c.color}" onclick="event.stopPropagation();changeCircuitColor('${c.id}')"></div>
      <div style="flex:1;min-width:0;overflow:hidden">
        <div style="display:flex;align-items:center;gap:3px">
          <div class="cname" style="flex:1" id="cn_${c.id}">${c.name}</div>
          <span style="font-size:9px;color:var(--dim);cursor:pointer;flex-shrink:0" onclick="event.stopPropagation();editCircuit('${c.id}')" title="Naam/kabelnr bewerken">✏</span>
        </div>
        ${c.kabelnr?`<div style="font-size:8.5px;color:var(--amber);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.kabelnr}</div>`:''}
      </div>
      <div class="ccnt">${cables.filter(k=>k.circuit===c.id).length}k/${elements.filter(e=>e.circuit===c.id).length}el</div>
    </div>`).join('');
}
function editCircuit(id){
  const c=circuits.find(x=>x.id===id);if(!c)return;
  const name=prompt('Naam kring:',c.name);
  if(name===null)return;
  if(name.trim())c.name=name.trim();
  const kabelnr=prompt('Kabelnummer automaat (leeg = geen prefix):',c.kabelnr||'');
  if(kabelnr!==null)c.kabelnr=kabelnr.trim();
  // if kabelnr changed, reset counters for this circuit
  if(kabelnr!==c.kabelnr){
    Object.keys(circTypeCounters).filter(k=>k.startsWith(id+'_')).forEach(k=>delete circTypeCounters[k]);
    Object.keys(lastPlacedLabel).filter(k=>k.startsWith(id+'_')).forEach(k=>delete lastPlacedLabel[k]);
  }
  renderCircuits();redraw();
}
function changeCircuitColor(id){
  const inp=document.createElement('input');inp.type='color';
  const c=circuits.find(x=>x.id===id);if(!c)return;
  inp.value=c.color;
  inp.oninput=e=>{
    c.color=e.target.value;
    // update all cables in this circuit
    cables.filter(k=>k.circuit===id).forEach(k=>k.color=e.target.value);
    renderCircuits();redraw();
  };
  inp.click();
}

// ── SEARCH ────────────────────────────────────────────────────────────────────
let searchQ='';
function doSearch(q){
  searchQ=q.trim().toLowerCase();
  document.getElementById('searchClear').classList.toggle('show',!!searchQ);
  if(!searchQ){closeSearch();redraw();return;}
  const results=[];
  elements.forEach(el=>{
    const circ=circuits.find(c=>c.id===el.circuit);
    const hay=[el.label,el.ref,el.armatuurtype,el.kasttype,el.notes,el.hoogte||'',TYPEINFO[el.type]?.lbl||'',circ?circ.name:'',circ?circ.kabelnr:''].join(' ').toLowerCase();
    if(hay.includes(searchQ)) results.push({kind:'elem',obj:el,circ});
  });
  cables.forEach(c=>{
    const from=elements.find(e=>e.id===c.fromId),to=elements.find(e=>e.id===c.toId);
    const hay=[c.kabelnr,c.kabeltype,c.notes,from?from.label:'',to?to.label:''].join(' ').toLowerCase();
    if(hay.includes(searchQ)) results.push({kind:'cable',obj:c,from,to});
  });
  const box=document.getElementById('searchResults');
  if(!results.length){
    box.innerHTML='<div style="padding:10px;font-size:11px;color:var(--dim)">Geen resultaten gevonden</div>';
    box.classList.add('show');return;
  }
  box.innerHTML=results.slice(0,30).map(r=>{
    if(r.kind==='elem'){
      const col=r.circ?r.circ.color:'#fff';
      return `<div class="sr-item" onclick="selectAndJump('${r.obj.id}')">
        <div class="sr-dot" style="background:${col}"></div>
        <div class="sr-main">${r.obj.label} — ${TYPEINFO[r.obj.type]?.lbl||r.obj.type}
          <div class="sr-sub">${r.obj.armatuurtype||r.obj.kasttype||''}${r.circ?' · '+r.circ.name:''}</div>
        </div>
        <span style="font-size:10px;color:var(--dim)">${TYPEINFO[r.obj.type]?.icon||''}</span>
      </div>`;
    } else {
      const len=cLen(r.obj).toFixed(1);
      return `<div class="sr-item" onclick="selectAndJump('cable:${r.obj.id}')">
        <div class="sr-dot" style="background:${r.obj.color||'#fff'}"></div>
        <div class="sr-main">${r.obj.kabelnr} — ${r.obj.kabeltype||'—'}
          <div class="sr-sub">${r.from?r.from.label:'?'} → ${r.to?r.to.label:'?'} · ${len}m</div>
        </div>
        <span style="font-size:10px;color:var(--amber)">${len}m</span>
      </div>`;
    }
  }).join('');
  box.classList.add('show');
}
function searchKey(e){if(e.key==='Escape')clearSearch();}
function clearSearch(){
