  highlightId=id;
  renderProps();
  // pan/zoom to element
  let tx,ty;
  if(id.startsWith('cable:')){
    const c=cables.find(x=>x.id===id.replace('cable:',''));
    if(c){const pts=cPts(c);const m=ptMid(pts);tx=m.x;ty=m.y;}
